# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
APP_ENV=development
LOG_LEVEL=info

# Model providers
# Add real keys only in local private env files. Never commit real secrets.
GEMINI_API_KEY=
MIMO_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google Cloud / Firebase
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE=
CLOUD_STORAGE_BUCKET=

# Demo / fallback mode
ENABLE_DEMO_MODE=true
DEMO_FIXTURE_PATH=./fixtures/payloads/demo_board_payload.json
