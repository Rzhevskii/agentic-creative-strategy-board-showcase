{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agentic-creative-strategy-board/shared/schemas/board-payload.schema.json",
  "title": "BoardPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionId",
    "runId",
    "mode",
    "input",
    "sources",
    "patternClusters",
    "overused",
    "opportunities",
    "nextTestBrief",
    "audioRecap",
    "storyBlocks"
  ],
  "properties": {
    "sessionId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["live", "fallback"] },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["brief", "targetNiche"],
      "properties": {
        "brief": { "type": "string", "minLength": 1 },
        "contextUrl": { "type": ["string", "null"], "format": "uri" },
        "inputImagePath": { "type": ["string", "null"] },
        "targetNiche": { "type": "string", "minLength": 1 }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "title", "url", "domain", "citationLabel"],
        "properties": {
          "sourceId": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "domain": { "type": "string", "minLength": 1 },
          "screenshotPath": { "type": ["string", "null"] },
          "citationLabel": { "type": "string", "minLength": 1 }
        }
      }
    },
    "patternClusters": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clusterId", "label", "summary", "evidenceSourceIds", "evidenceCount"],
        "properties": {
          "clusterId": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "evidenceSourceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "evidenceCount": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "overused": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "reason", "evidenceSourceIds"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "evidenceSourceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "opportunities": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "rationale", "differentiationAngle", "evidenceSourceIds"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "differentiationAngle": { "type": "string", "minLength": 1 },
          "evidenceSourceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "nextTestBrief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audience", "hook", "angle", "visualDirection", "copyDirection", "whyThisNow"],
      "properties": {
        "audience": { "type": "string", "minLength": 1 },
        "hook": { "type": "string", "minLength": 1 },
        "angle": { "type": "string", "minLength": 1 },
        "visualDirection": { "type": "string", "minLength": 1 },
        "copyDirection": { "type": "string", "minLength": 1 },
        "whyThisNow": { "type": "string", "minLength": 1 }
      }
    },
    "audioRecap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["ready", "unavailable"] },
        "audioPath": { "type": "string" },
        "transcript": { "type": "string" }
      }
    },
    "storyBlocks": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["blockId", "type"],
        "properties": {
          "blockId": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["narrative_text", "source_collage", "generated_image", "audio_clip", "strategy_callout", "citation_callout"]
          }
        },
        "additionalProperties": true
      }
    },
    "visualBlocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["blockId", "type"],
        "properties": {
          "blockId": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["bar_chart", "comparison_table", "timeline", "matrix_2x2", "quote_strip", "signal_meter"]
          }
        },
        "additionalProperties": true
      }
    }
  }
}
